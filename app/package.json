{
  "private": true,
  "name": "scribbits",
  "version": "0.0.0",
  "packageManager": "pnpm@11.7.0",
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "balance": "node tools/balancer/run.mjs",
    "balance:check": "node tools/balancer/run.mjs --check",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 vite build && node scripts/verify-devvit-build.mjs",
    "deploy": "pnpm run release:check && NODE_OPTIONS=--max-old-space-size=4096 devvit upload --bump patch",
    "dev": "NODE_OPTIONS=--max-old-space-size=4096 devvit playtest",
    "launch": "pnpm run release:check && NODE_OPTIONS=--max-old-space-size=4096 devvit publish --bump patch",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "login": "devvit login",
    "mock": "../mock.command",
    "prettier": "prettier --write .",
    "release:check": "pnpm run verify && pnpm run balance:check && devvit whoami",
    "test": "node scripts/run-test-suites.mjs",
    "test:devvit": "node scripts/test-devvit-playtest.mjs",
    "test:suites": "node scripts/run-test-suites.mjs --suites-only",
    "test:sim": "node scripts/test-battle.mjs",
    "type-check": "node scripts/clean-type-output.mjs && tsc --build --force",
    "verify": "pnpm run type-check && pnpm run lint && pnpm test && pnpm run build"
  },
  "engines": {
    "node": ">=22.2.0"
  },
  "dependencies": {
    "@devvit/start": "0.13.7",
    "@devvit/web": "0.13.7",
    "@fontsource/dynapuff": "5.2.8",
    "@hono/node-server": "2.0.6",
    "devvit": "0.13.7",
    "hono": "4.12.27",
    "phaser": "4.2.0",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "^22.19.19",
    "@types/pngjs": "^6.0.5",
    "eslint": "10.4.1",
    "globals": "17.7.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vite": "7.3.5"
  }
}
