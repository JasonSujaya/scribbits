{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "exactOptionalPropertyTypes": false,
    "ignoreDeprecations": "6.0",
    "incremental": false,
    "lib": ["DOM", "WebWorker", "ES2023"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "../src",
    "sourceMap": false,
    "types": ["node"]
  },
  "include": [
    "../src/shared/**/*.ts",
    "../src/server/core/**/*.ts",
    "../src/client/lib/arenaasynclifecycle.ts",
    "../src/client/lib/apiretry.ts",
    "../src/client/lib/api.ts",
    "../src/client/lib/appdockprogression.ts",
    "../src/client/lib/battlejournal.ts",
    "../src/client/lib/battleboard.ts",
    "../src/client/lib/battlepresentation.ts",
    "../src/client/lib/bucketfill.ts",
    "../src/client/lib/capsulereveal.ts",
    "../src/client/lib/capsulepresentation.ts",
    "../src/client/lib/coloreraser.ts",
    "../src/client/lib/cosmeticpreviewfit.ts",
    "../src/client/lib/drawautomation.ts",
    "../src/client/lib/drawcharges.ts",
    "../src/client/lib/drawroundclock.ts",
    "../src/client/lib/firstchesttrail.ts",
    "../src/client/lib/fittext.ts",
    "../src/client/lib/foundercharacterart.ts",
    "../src/client/lib/localization.ts",
    "../src/client/lib/legacyreturnpresentation.ts",
    "../src/client/lib/maturearena.ts",
    "../src/client/lib/maturitycountdown.ts",
    "../src/client/lib/paintreservoir.ts",
    "../src/client/lib/registry.ts",
    "../src/client/lib/replaycommentary.ts",
    "../src/client/lib/replaypostfighteligibility.ts",
    "../src/client/lib/replayreward.ts",
    "../src/client/lib/rumblereturnpresentation.ts",
    "../src/client/lib/semantictabs.ts",
    "../src/client/lib/theme.ts"
  ],
  "exclude": []
}
