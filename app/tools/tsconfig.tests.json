{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "exactOptionalPropertyTypes": false,
    "ignoreDeprecations": "6.0",
    "incremental": false,
    "lib": ["WebWorker", "ES2023"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "../src",
    "sourceMap": false,
    "types": ["node"]
  },
  "include": [
    "../src/shared/**/*.ts",
    "../src/server/core/**/*.ts",
    "../src/client/lib/coloreraser.ts",
    "../src/client/lib/fittext.ts",
    "../src/client/lib/replaypostfighteligibility.ts",
    "../src/client/lib/replayreward.ts"
  ],
  "exclude": []
}
