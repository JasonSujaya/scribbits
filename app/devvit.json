{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "scribbits",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "media": true,
    "redis": true,
    "reddit": {
      "enable": true,
      "scope": "moderator"
    }
  },
  "menu": {
    "items": [
      {
        "label": "Create Rumble post",
        "description": "Create today's Scribbits Arena post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "Manage Scribbits seasons",
        "description": "Create, schedule, pause, and finalize ranking seasons",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/seasons-manage"
      }
    ]
  },
  "forms": {
    "manageSeasons": "/internal/menu/seasons-submit"
  },
  "settings": {
    "global": {
      "seasonAdminUserIds": {
        "type": "string",
        "label": "Season admin Reddit user IDs",
        "helpText": "Comma-separated Reddit account IDs using the t2_ prefix.",
        "placeholder": "t2_abc,t2_def",
        "isSecret": true,
        "validationEndpoint": "/internal/menu/season-admin-user-ids-validate"
      }
    }
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onAppUpgrade": "/internal/triggers/on-app-upgrade"
  },
  "scheduler": {
    "tasks": {
      "nightly-arena": {
        "endpoint": "/internal/scheduler/nightly-arena",
        "cron": "0 0 * * *"
      }
    }
  },
  "scripts": {
    "build": "NODE_OPTIONS=--max-old-space-size=4096 vite build",
    "dev": "vite build --watch"
  },
  "dev": {
    "subreddit": "scribbits_dev"
  }
}
